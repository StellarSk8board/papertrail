{
  "name": "papertrail",
  "version": "0.3.0",
  "description": "AI agent orchestration tool",
  "author": "PaperTrail Team",
  "private": true,
  "main": "electron/main.js",
  "license": "GPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || echo \"WARN: electron-rebuild failed — run 'npm run postinstall' after installing Visual Studio Build Tools\"",
    "electron:dev": "vite build && cross-env VERBOSE_LOGGING=true electron .",
    "electron:build": "vite build && electron-builder --config electron-builder.yml",
    "electron:publish": "vite build && electron-builder --config electron-builder.yml --publish always",
    "generate-ico": "node scripts/generate-ico.js",
    "version": "bash scripts/bump-version.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "better-sqlite3": "^12.8.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^10.0.1",
    "cross-env": "^7.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.0",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "phaser": "^3.90.0",
    "png-to-ico": "^2.1.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "uuid": "^13.0.0",
    "vite": "^8.0.3"
  }
}
